NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nextdraft

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# Cloudinary - file storage for resumes
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Gemini - AI suggestion engine
# Get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Email (Nodemailer) - leave blank to use Ethereal test account in dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NextDraft <noreply@nextdraft.app>

# Frontend URL for email links
FRONTEND_URL=http://localhost:3000
