# ==================
# Server
# ==================
NODE_ENV=production
PORT=5000

# Comma-separated list of allowed frontend origins.
# In prod this MUST be set (CORS will deny everything else).
# e.g. https://next-draft-dun.vercel.app,https://nextdraft.app
FRONTEND_URL=https://next-draft-dun.vercel.app

# ==================
# Database (MongoDB Atlas)
# Either name works; MONGODB_URI is the new canonical name.
# ==================
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nextdraft

# ==================
# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ==================
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRE=7d

# ==================
# Cloudinary - file storage
# ==================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==================
# Google Gemini - AI suggestion engine
# Key: https://aistudio.google.com/app/apikey
# ==================
GEMINI_API_KEY=

# ==================
# Razorpay - REQUIRED for paid points purchases.
# Without these set, the buy-points UI shows a disabled state and only
# admin manual credits or the free starter pack work.
# Dashboard: https://dashboard.razorpay.com/app/keys
# ==================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ==================
# Email (Nodemailer)
# Leave blank to use Ethereal test account in dev. REQUIRED in production.
# ==================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NextDraft <noreply@nextdraft.app>
